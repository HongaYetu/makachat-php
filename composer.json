{
    "name": "hongayetu/honga-hub-php",
    "description": "SDK Laravel do Honga Hub: emissão de tokens, cliente s2s, barramento de eventos e assinatura de conectores",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10|^7.0",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Hongayetu\\HongaHub\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hongayetu\\HongaHub\\HongaHubServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "homepage": "https://github.com/HongaYetu/honga-hub-php",
    "support": {
        "source": "https://github.com/HongaYetu/honga-hub-php",
        "issues": "https://github.com/HongaYetu/honga-hub-php/issues"
    }
}
